# Copy to .env.local for development. Never commit the real .env.local.

# Base URL of the Django backend. Server-side only — this is fetched from
# Server Components, never from the browser, so it needs no NEXT_PUBLIC_ prefix
# and no CORS entry on the backend.
#
# Defaults to http://127.0.0.1:8000 (what `manage.py runserver` serves) when
# unset, so local development works with no .env.local at all.
API_URL=http://127.0.0.1:8000
